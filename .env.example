# CipherPulse Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env — it is in .gitignore.

# ── Anthropic API (script_writer.py, seo_generator.py) ──────────────────────
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Pexels API (footage_downloader.py) ──────────────────────────────────────
# Get from: https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_api_key_here

# ── YouTube Data API v3 (youtube_uploader.py) ────────────────────────────────
# Get from: https://console.cloud.google.com/ → Create project → Enable YouTube Data API v3
# → Credentials → OAuth 2.0 Client ID (Desktop app)
YOUTUBE_CLIENT_ID=your_youtube_client_id_here
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret_here

# ── TikTok Content Posting API (tiktok_uploader.py) ─────────────────────────
# Get from: https://developers.tiktok.com/ → Request video.upload + video.publish scopes
# Enable only after TikTok Developer approval. Set tiktok.enabled=true in config/platforms.json.
TIKTOK_CLIENT_KEY=your_tiktok_client_key_here
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret_here

# ── Instagram Graph API (instagram_uploader.py) ──────────────────────────────
# Get from: https://developers.facebook.com/ → Create app → Instagram Graph API
# Requires: Instagram Creator/Business account + Facebook Page linked
# Enable only after Facebook Developer app approval.
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token_here
INSTAGRAM_ACCOUNT_ID=your_instagram_account_id_here
